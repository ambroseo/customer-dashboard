{
    "name": "ambroseo/customer-dashboard",
    "description": "Customer-Admin-Dashboard fuer AMBROSEO-Kundenwebseiten. Liefert Server-Status, Aktivitaets-Stats, Direkt-Chat zu AMBROSEO + Hilfe-Center als Filament-Plugin. Pulled Branding + Daten zentral aus AMBROSEO-API.",
    "version": "1.0.0",
    "type": "library",
    "license": "proprietary",
    "keywords": ["ambroseo", "filament", "customer-dashboard", "hosting"],
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0",
        "filament/widgets": "^4.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Ambroseo\\CustomerDashboard\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ambroseo\\CustomerDashboard\\CustomerDashboardServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
